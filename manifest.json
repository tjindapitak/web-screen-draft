{
  "manifest_version": 3,
  "name": "Web Screen Draft",
  "version": "1.0.0",
  "description": "Edit, annotate, draw, and screenshot any webpage with side-by-side comparisons.",
  "homepage_url": "https://github.com/tjindapitak/web-screen-draft",
  "author": "Thanapon Jindapitak",
  "short_name": "Web Screen Draft",
  "privacy_policy": "https://github.com/tjindapitak/web-screen-draft/blob/main/PRIVACY.md",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "clipboardRead"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-edit": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Toggle edit mode"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
