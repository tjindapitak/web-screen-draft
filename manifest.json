{
  "manifest_version": 3,
  "name": "Web Screen Draft",
  "version": "1.0.0",
  "description": "Edit, move, paste, and screenshot any webpage — a tool for legal, product, and compliance teams.",
  "homepage_url": "https://github.com/your-username/web-screen-draft",
  "author": "Your Name",
  "short_name": "Web Screen Draft",
  "privacy_policy": "https://github.com/your-username/web-screen-draft/blob/main/PRIVACY.md",
  "permissions": [
    "activeTab",
    "downloads",
    "clipboardRead"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-edit": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Toggle edit mode"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/html2canvas.min.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
